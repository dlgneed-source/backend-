# eAkhuwat Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/eakhuwat

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (for referral links)
FRONTEND_URL=http://localhost:5173

# Blockchain
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_WALLET=0x0000000000000000000000000000000000000002
CHAIN_ID=1
SIGNER_PRIVATE_KEY=your-treasury-signer-private-key

# EIP-712
EIP712_DOMAIN_NAME=eAkhuwat
EIP712_DOMAIN_VERSION=1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin
ADMIN_WALLET=0x0000000000000000000000000000000000000001

# Withdrawal Limits
WITHDRAWAL_MIN_AMOUNT=5
WITHDRAWAL_MAX_AMOUNT=10000

# Gift Code
GIFT_CODE_EXPIRY_DAYS=30
