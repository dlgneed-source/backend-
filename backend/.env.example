# eAkhuwat Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/eakhuwat

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (for referral links)
FRONTEND_URL=http://localhost:5173

# Blockchain
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
CONTRACT_ADDRESS=<REPLACE_WITH_CONTRACT_ADDRESS>
TREASURY_WALLET=<REPLACE_WITH_TREASURY_WALLET>
CHAIN_ID=<REPLACE_WITH_CHAIN_ID>
SIGNER_PRIVATE_KEY=<REPLACE_WITH_64_HEX_PRIVATE_KEY>

# EIP-712
EIP712_DOMAIN_NAME=eAkhuwat
EIP712_DOMAIN_VERSION=1
EIP712_WITHDRAWAL_TTL_SECONDS=3600
EIP712_MAX_DEADLINE_SECONDS=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin
ADMIN_WALLET=0x0000000000000000000000000000000000000001
ADMIN_LOGIN_ID=admin_login_id
ADMIN_LOGIN_PASSWORD=change_me_strong_password

# Withdrawal Limits
WITHDRAWAL_MIN_AMOUNT=5
WITHDRAWAL_MAX_AMOUNT=10000

# Gift Code
GIFT_CODE_EXPIRY_DAYS=30
