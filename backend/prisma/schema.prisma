// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
  PENDING
}

enum EnrollmentStatus {
  ACTIVE
  MATURED
  FLUSHED
  PENDING
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  COMPLETED
}

enum TransactionType {
  DEPOSIT
  COMMISSION
  WITHDRAWAL
  REFERRAL_BONUS
  FLUSHOUT
  INCENTIVE
  POOL_DISTRIBUTION
  SYSTEM_FEE
  GIFT_CODE
  UPLINE_COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PoolType {
  SYSTEM
  LEADER
  REWARD
  SPONSOR
}

enum IncentiveRank {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum IncentiveClaimStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum GiftCodeStatus {
  ACTIVE
  USED
  EXPIRED
  DISABLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum AuditAction {
  USER_CREATED
  USER_SUSPENDED
  USER_BLOCKED
  ENROLLMENT_CREATED
  ENROLLMENT_FLUSHED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  GIFT_CODE_CREATED
  GIFT_CODE_DISABLED
  INCENTIVE_APPROVED
  INCENTIVE_REJECTED
  POOL_DISTRIBUTED
  SYSTEM_CONFIG_UPDATED
  ADMIN_CREATED
}

// =============================================
// MODELS
// =============================================

model User {
  id                 String            @id @default(cuid())
  walletAddress      String            @unique
  email              String?           @unique
  name               String?
  status             UserStatus        @default(ACTIVE)
  referralCode       String            @unique
  referredById       String?
  referredBy         User?             @relation("UserReferrals", fields: [referredById], references: [id])
  referrals          User[]            @relation("UserReferrals")
  nonce              String?
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  enrollments        Enrollment[]
  commissionsEarned  Commission[]      @relation("CommissionRecipient")
  commissionsPaid    Commission[]      @relation("CommissionPayer")
  uplineCommissions  UplineCommission[] @relation("UplineRecipient")
  withdrawals        Withdrawal[]
  transactions       Transaction[]
  giftCodesGenerated GiftCode[]        @relation("GiftCodeGenerator")
  giftCodeRedemptions GiftCodeRedemption[]
  incentiveClaims    IncentiveClaim[]
  auditLogs          AuditLog[]

  @@index([walletAddress])
  @@index([referralCode])
  @@index([referredById])
}

model Plan {
  id               Int       @id
  name             String    @unique
  joiningFee       Float
  teamSize         Int
  uplineCommission Float
  systemFee        Float
  levelCommission  Float
  slotFee          Float
  totalCollection  Float
  memberProfit     Float
  leaderPool       Float
  rewardPool       Float
  sponsorPool      Float
  roi              Float
  flushoutDays     Int
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  enrollments      Enrollment[]
  pools            Pool[]
  giftCodes        GiftCode[]
}

model Enrollment {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  planId           Int
  plan             Plan             @relation(fields: [planId], references: [id])
  status           EnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime         @default(now())
  flushoutAt       DateTime?
  maturedAt        DateTime?
  txHash           String?
  referralsCount   Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  referrals        EnrollmentReferral[] @relation("EnrollmentSource")
  referredBy       EnrollmentReferral[] @relation("EnrollmentReferee")
  commissions      Commission[]
  poolDistributions PoolDistribution[]

  @@index([userId])
  @@index([planId])
  @@index([status])
}

model EnrollmentReferral {
  id                 String     @id @default(cuid())
  enrollmentId       String
  enrollment         Enrollment @relation("EnrollmentSource", fields: [enrollmentId], references: [id])
  referredEnrollmentId String
  referredEnrollment Enrollment @relation("EnrollmentReferee", fields: [referredEnrollmentId], references: [id])
  level              Int
  createdAt          DateTime   @default(now())

  @@unique([enrollmentId, referredEnrollmentId])
  @@index([enrollmentId])
}

model SystemFeeLedger {
  id           String   @id @default(cuid())
  enrollmentId String
  planId       Int
  amount       Float
  description  String?
  createdAt    DateTime @default(now())

  @@index([planId])
}

model UplineCommission {
  id           String   @id @default(cuid())
  enrollmentId String
  recipientId  String
  recipient    User     @relation("UplineRecipient", fields: [recipientId], references: [id])
  amount       Float
  planId       Int
  txHash       String?
  createdAt    DateTime @default(now())

  @@index([recipientId])
  @@index([planId])
}

model Commission {
  id            String     @id @default(cuid())
  fromUserId    String
  fromUser      User       @relation("CommissionPayer", fields: [fromUserId], references: [id])
  toUserId      String
  toUser        User       @relation("CommissionRecipient", fields: [toUserId], references: [id])
  enrollmentId  String
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id])
  level         Int
  percentage    Float
  amount        Float
  planId        Int
  txHash        String?
  createdAt     DateTime   @default(now())

  @@index([toUserId])
  @@index([fromUserId])
  @@index([enrollmentId])
  @@index([planId])
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  amount        Float
  walletAddress String
  status        WithdrawalStatus @default(PENDING)
  signature     String?
  nonce         String?          @unique
  txHash        String?
  requestedAt   DateTime         @default(now())
  processedAt   DateTime?
  rejectedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

model Pool {
  id               String             @id @default(cuid())
  planId           Int
  plan             Plan               @relation(fields: [planId], references: [id])
  type             PoolType
  balance          Float              @default(0)
  totalReceived    Float              @default(0)
  totalDistributed Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  distributions    PoolDistribution[]

  @@unique([planId, type])
  @@index([planId])
}

model PoolDistribution {
  id           String     @id @default(cuid())
  poolId       String
  pool         Pool       @relation(fields: [poolId], references: [id])
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  amount       Float
  description  String?
  txHash       String?
  distributedAt DateTime  @default(now())
  createdAt    DateTime   @default(now())

  @@index([poolId])
  @@index([enrollmentId])
}

model GiftCode {
  id           String         @id @default(cuid())
  code         String         @unique
  planId       Int
  customAmount Float?
  plan         Plan           @relation(fields: [planId], references: [id])
  generatedById String
  generatedBy  User           @relation("GiftCodeGenerator", fields: [generatedById], references: [id])
  status       GiftCodeStatus @default(ACTIVE)
  expiresAt    DateTime?
  usedAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  redemption   GiftCodeRedemption?

  @@index([code])
  @@index([planId])
  @@index([status])
}

model GiftCodeRedemption {
  id          String   @id @default(cuid())
  giftCodeId  String   @unique
  giftCode    GiftCode @relation(fields: [giftCodeId], references: [id])
  redeemedById String
  redeemedBy  User     @relation(fields: [redeemedById], references: [id])
  redeemedAt  DateTime @default(now())
  enrollmentId String?
  createdAt   DateTime @default(now())

  @@index([redeemedById])
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  description String?
  status      TransactionStatus @default(COMPLETED)
  txHash      String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model IncentiveClaim {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  rank        IncentiveRank
  reward      Float
  status      IncentiveClaimStatus @default(PENDING)
  claimedAt   DateTime             @default(now())
  approvedAt  DateTime?
  paidAt      DateTime?
  txHash      String?
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([rank])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Admin {
  id           String    @id @default(cuid())
  walletAddress String   @unique
  email        String?   @unique
  name         String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  passwordHash String?
  nonce        String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs    AuditLog[]
}

model AuditLog {
  id          String      @id @default(cuid())
  adminId     String?
  admin       Admin?      @relation(fields: [adminId], references: [id])
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  action      AuditAction
  description String
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@index([adminId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Treasury {
  id               String          @id @default(cuid())
  totalDeposited   Float           @default(0)
  totalWithdrawn   Float           @default(0)
  totalCommissions Float           @default(0)
  totalSystemFees  Float           @default(0)
  totalPoolFunds   Float           @default(0)
  balance          Float           @default(0)
  updatedAt        DateTime        @updatedAt
  createdAt        DateTime        @default(now())

  ledgerEntries    TreasuryLedger[]
}

model TreasuryLedger {
  id          String   @id @default(cuid())
  treasuryId  String
  treasury    Treasury @relation(fields: [treasuryId], references: [id])
  credit      Float    @default(0)
  debit       Float    @default(0)
  balance     Float
  description String
  reference   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([treasuryId])
  @@index([createdAt])
}
