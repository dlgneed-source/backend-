// ============================================================================
// eAKHUWAT - PRODUCTION DATABASE SCHEMA
// ============================================================================
// All financial fields use Decimal(20,8) for exact precision
// ============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MODEL
// ============================================================================
model User {
  id             String     @id @default(uuid())
  walletAddress  String     @unique
  name           String?
  email          String?    @unique
  status         UserStatus @default(ACTIVE)
  joinedAt       DateTime   @default(now())
  lastActiveAt   DateTime   @default(now())

  // Financial fields with high precision
  totalInvested  Decimal @default(0.0) @db.Decimal(20, 8)
  totalEarned    Decimal @default(0.0) @db.Decimal(20, 8)
  totalWithdrawn Decimal @default(0.0) @db.Decimal(20, 8)
  balance        Decimal @default(0.0) @db.Decimal(20, 8)

  // EIP-712 Replay Protection
  nonce Int @default(0)

  // Referral system
  referrerId String?
  referrer   User?  @relation("ReferralTree", fields: [referrerId], references: [id])
  referrals  User[] @relation("ReferralTree")

  // Relations
  enrollments        Enrollment[]
  withdrawals        Withdrawal[]
  commissionsSent    Commission[]       @relation("CommissionFrom")
  commissionsRecv    Commission[]       @relation("CommissionTo")
  transactions       Transaction[]
  incentiveClaims    IncentiveClaim[]
  poolDistributions  PoolDistribution[]
  giftCodeRedemptions GiftCodeRedemption[]
  treasuryLedgers    TreasuryLedger[]

  // Chat relations
  chatRoomMemberships ChatRoomMember[]
  chatMessages        ChatMessage[]
  messageReactions    MessageReaction[]
  sentDMs             DirectMessage[]    @relation("DMSender")
  receivedDMs         DirectMessage[]    @relation("DMReceiver")

  @@index([walletAddress])
  @@index([referrerId])
  @@index([status])
  @@index([joinedAt])
}

// ============================================================================
// PLAN MODEL - Fixed Values from Income Model
// ============================================================================
model Plan {
  id               Int     @id // Plan 1 to 6
  name             String
  joiningFee       Decimal @db.Decimal(20, 8)
  teamSize         Int
  uplineCommission Decimal @db.Decimal(20, 8)
  systemFee        Decimal @db.Decimal(20, 8)
  levelCommission  Decimal @db.Decimal(20, 8)
  slotFee          Decimal @db.Decimal(20, 8)
  totalCollection  Decimal @db.Decimal(20, 8)
  memberProfit     Decimal @db.Decimal(20, 8)
  leaderPool       Decimal @db.Decimal(20, 8)
  rewardPool       Decimal @db.Decimal(20, 8)
  sponsorPool      Decimal @db.Decimal(20, 8)
  roi              Decimal @db.Decimal(5, 2)
  flushoutDays     Int
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())

  enrollments       Enrollment[]
  pools             Pool[]
  systemFeeLedgers  SystemFeeLedger[]
  uplineCommissions UplineCommission[]
  treasuryLedgers   TreasuryLedger[]

  @@index([isActive])
}

// ============================================================================
// ENROLLMENT MODEL
// ============================================================================
model Enrollment {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  planId       Int
  plan         Plan             @relation(fields: [planId], references: [id])
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  expiresAt    DateTime
  maturedAt    DateTime?
  teamFilled   Int              @default(0)
  profitPaid   Boolean          @default(false)
  profitAmount Decimal          @default(0.0) @db.Decimal(20, 8)

  referrals        EnrollmentReferral[]
  systemFeeLedger  SystemFeeLedger?
  uplineCommission UplineCommission?
  treasuryLedgers  TreasuryLedger[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================================
// ENROLLMENT REFERRAL MODEL
// ============================================================================
model EnrollmentReferral {
  id             String     @id @default(uuid())
  enrollmentId   String
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  referredUserId String
  referredAt     DateTime   @default(now())

  @@index([enrollmentId])
  @@index([referredUserId])
}

// ============================================================================
// SYSTEM FEE LEDGER
// ============================================================================
model SystemFeeLedger {
  id           String     @id @default(uuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  planId       Int
  plan         Plan       @relation(fields: [planId], references: [id])
  amount       Decimal    @db.Decimal(20, 8)
  createdAt    DateTime   @default(now())

  @@index([planId])
  @@index([createdAt])
}

// ============================================================================
// UPLINE COMMISSION MODEL
// ============================================================================
model UplineCommission {
  id           String     @id @default(uuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  planId       Int
  plan         Plan       @relation(fields: [planId], references: [id])
  referrerId   String
  amount       Decimal    @db.Decimal(20, 8)
  createdAt    DateTime   @default(now())

  @@index([planId])
  @@index([referrerId])
}

// ============================================================================
// COMMISSION MODEL - Level commissions (7 levels)
// ============================================================================
model Commission {
  id           String   @id @default(uuid())
  fromUserId   String
  fromUser     User     @relation("CommissionFrom", fields: [fromUserId], references: [id])
  toUserId     String
  toUser       User     @relation("CommissionTo", fields: [toUserId], references: [id])
  amount       Decimal  @db.Decimal(20, 8)
  level        Int
  planId       Int
  enrollmentId String?
  createdAt    DateTime @default(now())

  @@index([toUserId])
  @@index([fromUserId])
  @@index([planId])
  @@index([createdAt])
}

// ============================================================================
// WITHDRAWAL MODEL
// ============================================================================
model Withdrawal {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  amount      Decimal          @db.Decimal(20, 8)
  status      WithdrawalStatus @default(PENDING)
  signature   String?
  txHash      String?
  requestedAt DateTime         @default(now())
  processedAt DateTime?
  processedBy String?
  failReason  String?

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
}

// ============================================================================
// POOL MODEL
// ============================================================================
model Pool {
  id               String             @id @default(uuid())
  name             String
  planId           Int
  plan             Plan               @relation(fields: [planId], references: [id])
  type             PoolType
  balance          Decimal            @default(0.0) @db.Decimal(20, 8)
  totalDistributed Decimal            @default(0.0) @db.Decimal(20, 8)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  distributions    PoolDistribution[]

  @@unique([planId, type])
  @@index([planId])
}

// ============================================================================
// POOL DISTRIBUTION MODEL
// ============================================================================
model PoolDistribution {
  id            String   @id @default(uuid())
  poolId        String
  pool          Pool     @relation(fields: [poolId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Decimal  @db.Decimal(20, 8)
  distributedAt DateTime @default(now())
  distributedBy String

  @@index([poolId])
  @@index([userId])
}

// ============================================================================
// GIFT CODE MODEL
// ============================================================================
model GiftCode {
  id          String         @id @default(uuid())
  code        String         @unique
  amount      Decimal        @db.Decimal(20, 8)
  maxUses     Int
  usedCount   Int            @default(0)
  expiresAt   DateTime
  status      GiftCodeStatus @default(ACTIVE)
  createdBy   String
  createdAt   DateTime       @default(now())
  redemptions GiftCodeRedemption[]

  @@index([code])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================================
// GIFT CODE REDEMPTION MODEL
// ============================================================================
model GiftCodeRedemption {
  id         String   @id @default(uuid())
  giftCodeId String
  giftCode   GiftCode @relation(fields: [giftCodeId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  redeemedAt DateTime @default(now())
  amount     Decimal  @db.Decimal(20, 8)

  @@index([giftCodeId])
  @@index([userId])
}

// ============================================================================
// TRANSACTION MODEL
// ============================================================================
model Transaction {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Decimal         @db.Decimal(20, 8)
  description String?
  referenceId String?
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// INCENTIVE CLAIM MODEL
// ============================================================================
model IncentiveClaim {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  type      IncentiveType
  planId    Int?
  tier      Int
  amount    Decimal       @db.Decimal(20, 8)
  status    ClaimStatus   @default(PENDING)
  proRata   Decimal?      @db.Decimal(3, 2)
  claimedAt DateTime?
  createdAt DateTime      @default(now())

  @@index([userId])
  @@index([type])
  @@index([status])
}

// ============================================================================
// SYSTEM CONFIG MODEL
// ============================================================================
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String
}

// ============================================================================
// ADMIN MODEL
// ============================================================================
model Admin {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  role          AdminRole @default(ADMIN)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
}

// ============================================================================
// AUDIT LOG MODEL
// ============================================================================
model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

// ============================================================================
// TREASURY MODEL
// ============================================================================
model Treasury {
  id            String           @id @default(uuid())
  key           String           @unique
  name          String
  walletAddress String?          @unique
  balance       Decimal          @default(0.0) @db.Decimal(20, 8)
  totalReceived Decimal          @default(0.0) @db.Decimal(20, 8)
  totalPaidOut  Decimal          @default(0.0) @db.Decimal(20, 8)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  ledgers       TreasuryLedger[]

  @@index([key])
  @@index([walletAddress])
}

// ============================================================================
// TREASURY LEDGER MODEL
// ============================================================================
model TreasuryLedger {
  id           String            @id @default(uuid())
  treasuryId   String
  treasury     Treasury          @relation(fields: [treasuryId], references: [id], onDelete: Cascade)
  planId       Int?
  plan         Plan?             @relation(fields: [planId], references: [id], onDelete: SetNull)
  enrollmentId String?
  enrollment   Enrollment?       @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         TreasuryEntryType
  amount       Decimal           @db.Decimal(20, 8)
  description  String?
  referenceId  String?
  createdAt    DateTime          @default(now())

  @@index([treasuryId])
  @@index([planId])
  @@index([enrollmentId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// ENUMS
// ============================================================================
enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum EnrollmentStatus {
  ACTIVE
  MATURED
  FLUSHED
  EXPIRED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

enum PoolType {
  LEADER
  REWARD
  SPONSOR
}

enum GiftCodeStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  DISABLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  COMMISSION
  ENROLLMENT
  GIFT_CODE
  POOL_DISTRIBUTION
  INCENTIVE
  PROFIT
  SYSTEM_FEE
  UPLINE_COMMISSION
}

enum IncentiveType {
  CLUB
  INDIVIDUAL
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  CLAIMED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum TreasuryEntryType {
  SYSTEM_FEE
  POOL_CONTRIBUTION
  WITHDRAWAL_FEE
  MANUAL_ADJUSTMENT
}

// ============================================================================
// CHAT ROOM MODEL
// ============================================================================
model ChatRoom {
  id          String           @id @default(uuid())
  name        String
  description String           @default("")
  isVip       Boolean          @default(false)
  isPinned    Boolean          @default(false)
  icon        String           @default("hash")
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members     ChatRoomMember[]
  messages    ChatMessage[]

  @@index([isVip])
  @@index([createdAt])
}

// ============================================================================
// CHAT ROOM MEMBER MODEL
// ============================================================================
model ChatRoomMember {
  id       String         @id @default(uuid())
  roomId   String
  room     ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     ChatMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

// ============================================================================
// CHAT MESSAGE MODEL
// ============================================================================
model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  replyToId String?
  isPinned  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions MessageReaction[]

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// MESSAGE REACTION MODEL
// ============================================================================
model MessageReaction {
  id        String      @id @default(uuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ============================================================================
// DIRECT MESSAGE MODEL
// ============================================================================
model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("DMSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("DMReceiver", fields: [receiverId], references: [id])
  text       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
  @@index([createdAt])
}

// ============================================================================
// CHAT ENUMS
// ============================================================================
enum ChatMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}
