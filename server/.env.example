# ============================================================================
# eAKHUWAT BACKEND - Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values
# ============================================================================

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/eakhuwat?schema=public"

# Server
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# EIP-712 / Smart Contract
ADMIN_PRIVATE_KEY=your-admin-wallet-private-key
CONTRACT_ADDRESS=0xYourSmartContractAddress
CHAIN_ID=56
EIP712_DOMAIN_NAME=eAkhuwat
EIP712_DOMAIN_VERSION=1

# CORS - Frontend URL
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
